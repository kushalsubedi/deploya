name: CI — {{ .RepoName }}

on:
  push:
    branches: [ "{{ .MainBranch }}" ]
  pull_request:
    branches: [ "{{ .MainBranch }}" ]
{{if .HasDocker }}
env:
  IMAGE_NAME: {{ .ImageName }}
{{end}}
jobs:

  # ── Build & Test ────────────────────────────────────────────────
  test:
    name: Build & Test
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      {{if eq .Language "go"}}
      - name: Set up Go {{ .Runtime }}
        uses: actions/setup-go@v5
        with:
          go-version: "{{ .Runtime }}"
          cache: true

      - name: Download dependencies
        run: go mod download

      - name: Build
        run: go build ./...

      {{else if eq .Language "python"}}
      - name: Set up Python {{ .Runtime }}
        uses: actions/setup-python@v5
        with:
          python-version: "{{ .Runtime }}"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          {{if .HasPipfile}}pip install pipenv && pipenv install --dev
          {{else if .HasPyproject}}pip install -e ".[dev]"
          {{else}}pip install -r requirements.txt
          {{end}}

      {{else if eq .Language "node"}}
      - name: Set up Node.js {{ .Runtime }}
        uses: actions/setup-node@v4
        with:
          node-version: "{{ .Runtime }}"
          cache: "npm"

      - name: Install dependencies
        run: npm ci

      {{if eq .Framework "nextjs"}}
      - name: Cache Next.js build
        uses: actions/cache@v4
        with:
          path: |
            ~/.npm
            ${{ "{{" }} github.workspace {{ "}}" }}/.next/cache
          key: ${{ "{{" }} runner.os {{ "}}" }}-nextjs-${{ "{{" }} hashFiles('**/package-lock.json') {{ "}}" }}
      {{end}}

      {{if .BuildCommand}}
      - name: Build
        run: {{ .BuildCommand }}
      {{end}}

      {{else if eq .Language "java"}}
      - name: Set up Java {{ .Runtime }}
        uses: actions/setup-java@v4
        with:
          java-version: "{{ .Runtime }}"
          distribution: "temurin"
          cache: "maven"

      {{else if eq .Language "ruby"}}
      - name: Set up Ruby {{ .Runtime }}
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: "{{ .Runtime }}"
          bundler-cache: true

      {{else if eq .Language "rust"}}
      - name: Set up Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Cache cargo
        uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/registry
            ~/.cargo/git
            target/
          key: ${{ "{{" }} runner.os {{ "}}" }}-cargo-${{ "{{" }} hashFiles('**/Cargo.lock') {{ "}}" }}
      {{end}}

      {{if .TestCommand}}
      - name: Run tests
        run: {{ .TestCommand }}
      {{end}}

  {{if .HasDocker}}
  # ── Docker Build & Push ───────────────────────────────────────────
  docker:
    name: Build & Push Docker image
    runs-on: ubuntu-latest
    needs: test

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      {{if eq .Registry "ghcr"}}
      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ "{{" }} github.actor {{ "}}" }}
          password: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}

      - name: Build and push to GHCR
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: ghcr.io/${{ "{{" }} github.repository_owner {{ "}}" }}/${{ "{{" }} env.IMAGE_NAME {{ "}}" }}:${{ "{{" }} github.sha {{ "}}" }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

      {{else if eq .Registry "dockerhub"}}
      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          registry: docker.io
          username: ${{ "{{" }} secrets.DOCKERHUB_USERNAME {{ "}}" }}
          password: ${{ "{{" }} secrets.DOCKERHUB_TOKEN {{ "}}" }}

      - name: Build and push to Docker Hub
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: ${{ "{{" }} secrets.DOCKERHUB_USERNAME {{ "}}" }}/${{ "{{" }} env.IMAGE_NAME {{ "}}" }}:${{ "{{" }} github.sha {{ "}}" }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

      {{else if eq .Registry "ecr"}}
      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ "{{" }} secrets.AWS_ACCESS_KEY_ID {{ "}}" }}
          aws-secret-access-key: ${{ "{{" }} secrets.AWS_SECRET_ACCESS_KEY {{ "}}" }}
          aws-region: ${{ "{{" }} secrets.AWS_REGION {{ "}}" }}

      - name: Login to Amazon ECR
        id: login-ecr
        uses: aws-actions/amazon-ecr-login@v2

      - name: Build and push to ECR
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: ${{ "{{" }} steps.login-ecr.outputs.registry {{ "}}" }}/${{ "{{" }} env.IMAGE_NAME {{ "}}" }}:${{ "{{" }} github.sha {{ "}}" }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

      {{else if eq .Registry "gcr"}}
      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ "{{" }} secrets.GCP_SA_KEY {{ "}}" }}

      - name: Build and push to GCR
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: gcr.io/${{ "{{" }} secrets.GCP_PROJECT_ID {{ "}}" }}/${{ "{{" }} env.IMAGE_NAME {{ "}}" }}:${{ "{{" }} github.sha {{ "}}" }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
      {{end}}
  {{end}}

  # ── Notify ────────────────────────────────────────────────────────
  {{if eq .Notify "slack"}}
  notify:
    name: Slack Notification
    runs-on: ubuntu-latest
    needs: [test{{if .HasDocker}}, docker{{end}}]
    if: always()

    steps:
      - name: Notify Slack
        uses: slackapi/slack-github-action@v1.26.0
        with:
          payload: |
            {
              "blocks": [
                {
                  "type": "header",
                  "text": {
                    "type": "plain_text",
                    "text": "${{ "{{" }} needs.test.result == 'success' && '✅ Pipeline Passed' || '❌ Pipeline Failed' {{ "}}" }} — {{ .RepoName }}"
                  }
                },
                {
                  "type": "section",
                  "fields": [
                    { "type": "mrkdwn", "text": "*Repository*\n{{ .RepoName }}" },
                    { "type": "mrkdwn", "text": "*Branch*\n${{ "{{" }} github.ref_name {{ "}}" }}" },
                    { "type": "mrkdwn", "text": "*Language*\n{{ .Language }} {{ .Runtime }}" },
                    { "type": "mrkdwn", "text": "*Triggered by*\n${{ "{{" }} github.actor {{ "}}" }}" },
                    { "type": "mrkdwn", "text": "*Commit*\n${{ "{{" }} github.sha {{ "}}" }}" },
                    { "type": "mrkdwn", "text": "*Tests*\n${{ "{{" }} needs.test.result {{ "}}" }}" }
                    {{if .HasDocker}},{ "type": "mrkdwn", "text": "*Docker*\n${{ "{{" }} needs.docker.result {{ "}}" }}" }{{end}}
                  ]
                },
                {
                  "type": "actions",
                  "elements": [
                    {
                      "type": "button",
                      "text": { "type": "plain_text", "text": "View Run" },
                      "url": "${{ "{{" }} github.server_url {{ "}}" }}/${{ "{{" }} github.repository {{ "}}" }}/actions/runs/${{ "{{" }} github.run_id {{ "}}" }}"
                    }
                  ]
                }
              ]
            }
        env:
          SLACK_WEBHOOK_URL: ${{ "{{" }} secrets.SLACK_WEBHOOK_URL {{ "}}" }}
          SLACK_WEBHOOK_TYPE: INCOMING_WEBHOOK

  {{else if eq .Notify "discord"}}
  notify:
    name: Discord Notification
    runs-on: ubuntu-latest
    needs: [test{{if .HasDocker}}, docker{{end}}]
    if: always()

    steps:
      - name: Notify Discord
        uses: tsickert/discord-webhook@v6.0.0
        with:
          webhook-url: ${{ "{{" }} secrets.DISCORD_WEBHOOK_URL {{ "}}" }}
          embed-title: "${{ "{{" }} needs.test.result == 'success' && '✅ Pipeline Passed' || '❌ Pipeline Failed' {{ "}}" }} — {{ .RepoName }}"
          embed-color: "${{ "{{" }} needs.test.result == 'success' && '3066993' || '15158332' {{ "}}" }}"
          embed-description: |
            **Repository** : {{ .RepoName }}
            **Branch**     : ${{ "{{" }} github.ref_name {{ "}}" }}
            **Language**   : {{ .Language }} {{ .Runtime }}
            {{if .Framework}}**Framework**  : {{ .Framework }}
            {{end}}**Triggered by**: ${{ "{{" }} github.actor {{ "}}" }}
            **Commit**     : ${{ "{{" }} github.sha {{ "}}" }}
            **Tests**      : ${{ "{{" }} needs.test.result {{ "}}" }}
            {{if .HasDocker}}**Docker**     : ${{ "{{" }} needs.docker.result {{ "}}" }}{{end}}

            [🔗 View Run](${{ "{{" }} github.server_url {{ "}}" }}/${{ "{{" }} github.repository {{ "}}" }}/actions/runs/${{ "{{" }} github.run_id {{ "}}" }})

  {{else if eq .Notify "email"}}
  notify:
    name: Email Notification
    runs-on: ubuntu-latest
    needs: [test{{if .HasDocker}}, docker{{end}}]
    if: always()

    steps:
      - name: Send email
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{ "{{" }} secrets.MAIL_USERNAME {{ "}}" }}
          password: ${{ "{{" }} secrets.MAIL_PASSWORD {{ "}}" }}
          to: ${{ "{{" }} secrets.MAIL_TO {{ "}}" }}
          from: GitHub Actions
          subject: "[${{ "{{" }} needs.test.result == 'success' && '✅ PASSED' || '❌ FAILED' {{ "}}" }}] {{ .RepoName }} — ${{ "{{" }} github.ref_name {{ "}}" }}"
          body: |
            CI Pipeline Summary — {{ .RepoName }}
            ─────────────────────────────────────
            Repository  : {{ .RepoName }}
            Branch      : ${{ "{{" }} github.ref_name {{ "}}" }}
            Commit      : ${{ "{{" }} github.sha {{ "}}" }}
            Triggered by: ${{ "{{" }} github.actor {{ "}}" }}
            Language    : {{ .Language }} {{ .Runtime }}
            {{if .Framework}}Framework   : {{ .Framework }}
            {{end}}
            ─────────────────────────────────────
            Job Results
            ─────────────────────────────────────
            Tests       : ${{ "{{" }} needs.test.result {{ "}}" }}
            {{if .HasDocker}}Docker      : ${{ "{{" }} needs.docker.result {{ "}}" }}
            {{end}}
            ─────────────────────────────────────
            View run: ${{ "{{" }} github.server_url {{ "}}" }}/${{ "{{" }} github.repository {{ "}}" }}/actions/runs/${{ "{{" }} github.run_id {{ "}}" }}
  {{end}}

  # ── Summary ───────────────────────────────────────────────────────
  summary:
    name: Summary
    runs-on: ubuntu-latest
    needs: [test{{if .HasDocker}}, docker{{end}}]
    if: always()

    steps:
      - name: Pipeline summary
        run: |
          echo "## 📊 CI Summary — {{ .RepoName }}" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| | Details |" >> $GITHUB_STEP_SUMMARY
          echo "|---|---|" >> $GITHUB_STEP_SUMMARY
          echo "| 🔤 Language | {{ .Language }} {{ .Runtime }} |" >> $GITHUB_STEP_SUMMARY
          {{if .Framework}}echo "| 🧩 Framework | {{ .Framework }} |" >> $GITHUB_STEP_SUMMARY
          {{end}}echo "| 🌿 Branch | ${{ "{{" }} github.ref_name {{ "}}" }} |" >> $GITHUB_STEP_SUMMARY
          echo "| 📝 Commit | ${{ "{{" }} github.sha {{ "}}" }} |" >> $GITHUB_STEP_SUMMARY
          echo "| 👤 Triggered by | ${{ "{{" }} github.actor {{ "}}" }} |" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "## Jobs" >> $GITHUB_STEP_SUMMARY
          echo "| Job | Status |" >> $GITHUB_STEP_SUMMARY
          echo "|-----|--------|" >> $GITHUB_STEP_SUMMARY
          echo "| 🧪 Tests | ${{ "{{" }} needs.test.result {{ "}}" }} |" >> $GITHUB_STEP_SUMMARY
          {{if .HasDocker}}echo "| 🐳 Docker | ${{ "{{" }} needs.docker.result {{ "}}" }} |" >> $GITHUB_STEP_SUMMARY
          {{end}}
